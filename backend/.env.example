# Copia questo file in ".env" e inserisci la tua chiave Semantic Scholar.
# La chiave NON va mai messa nel codice o committata su git.
S2_API_KEY=la-tua-chiave-qui

# secondi di attesa tra una chiamata e l'altra (con chiave il limite e' ~1 req/sec)
S2_RATE_DELAY=1.1

# anno corrente, usato per la "citation velocity" e il peso di recency del profilo
NEXUS_CURRENT_YEAR=2026
